{
  "name": "projecting-editor-nl-code",
  "displayName": "Projecting Editor Displaying Natural Language",
  "description": "",
  "publisher": "PeterVaverk",
  "repository": {
    "type": "git",
    "url": "https://github.com/PeterVavercak/projecting-editor-natural-language"
  },
  "version": "0.3.0",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:myToolsView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ProjectingNLEditor.writeNL",
        "title": "Write Natural Language",
        "category": "Projecting Natural Language Editor",
        "icon": "$(call-incoming)"
      },
      {
        "command": "ProjectingNLEditor.writeCode",
        "title": "Write Code",
        "category": "Projecting Natural Language Editor",
        "icon": "$(call-outgoing)"
      },
      {
        "command": "ProjectingNLEditor.generateRegions",
        "category": "Projecting Natural Language Editor",
        "title": "Generate Regions"
      },
      {
        "command": "ProjectingNLEditor.showNLRegions",
        "category": "Projecting Natural Language Editor",
        "title": "Show Natural Language Regions"
      },
      {
        "command": "ProjectingNLEditor.showCodeRegions",
        "category": "Projecting Natural Language Editor",
        "title": "Show Code Regions"
      },
      {
        "command": "ProjectingNLEditor.showEveryRegion",
        "category": "Projecting Natural Language Editor",
        "title": "Show Every Regions"
      },
      {
        "command": "ProjectingNLEditor.closeEveryRegion",
        "category": "Projecting Natural Language Editor",
        "title": "Close Every Regions"
      }
    ],
    "configuration": {
      "title": "Settings Editor Test Extension",
      "type": "object",
      "properties": {
        "projectingNaturalLanguage.setLanguageModel": {
          "type": "string",
          "enum": [
            "gpt-4o",
            "grok-code-fast-1",
            "gpt-5",
            "gpt-5-mini",
            "gpt-5-nano",
            "gpt-4.1",
            "gpt-4.1-mini",
            "gpt-4.1-nano",
            "gemini-2.5-pro",
            "claude-opus-4.6",
            "claude-sonnet-4.6"
          ],
          "enumItemLabels": [
            "Chat GPT 4o",
            "Grok",
            "Chat GPT 5",
            "Chat GPT 5 mini",
            "Chat GPT 5 nano",
            "Chat GPT 4.1",
            "Chat GPT 4.1 mini",
            "Chat Gpt 4.1 nano",
            "Gemini 2.5 Pro",
            "Claude Opus 4.6",
            "Claude Sonnet 4.6"
          ],
          "default": "gpt-4o",
          "description": "Language Model"
        },
        "projectingNaturalLanguage.automaticTranslation": {
          "type": "boolean",
          "default": true,
          "description": "Automatic Translation"
        },
        "projectingNaturalLanguage.automaticFolding": {
          "type": "boolean",
          "default": true,
          "description": "Automatic Folding"
        },
        "projectingNaturalLanguage.showDecorations": {
          "type": "boolean",
          "default": false,
          "description": "Show Decorations"
        },
        "projectingNaturalLanguage.excludedLanguages": {
          "order": 7,
          "type": "array",
          "default": [],
          "markdownDescription": "List of languages to exclude from folding. \n\nExample: `['javascript', 'typescript']`."
        }
      }
    },
    "snippets": [
      {
        "language": "c",
        "path": "./snippets/c.json"
      },
      {
        "language": "cpp",
        "path": "./snippets/cpp.json"
      },
      {
        "language": "csharp",
        "path": "./snippets/csharp.json"
      },
      {
        "language": "java",
        "path": "./snippets/java.json"
      },
      {
        "language": "javascript",
        "path": "./snippets/javascript.json"
      },
      {
        "language": "php",
        "path": "./snippets/php.json"
      },
      {
        "language": "python",
        "path": "./snippets/python.json"
      },
      {
        "language": "typescript",
        "path": "./snippets/typescript.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projecting-editor-bar",
          "title": "Projecting Editor",
          "icon": "resources/versions.svg"
        }
      ]
    },
    "views": {
      "projecting-editor-bar": [
        {
          "id": "projectingEditorView",
          "name": "Projecting Editor"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "dependencies": {
    "vscode-languageserver-protocol": "^3.17.5"
  }
}
