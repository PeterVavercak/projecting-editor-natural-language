{
  "name": "projecting-editor-nl-code",
  "displayName": "Projecting Editor using Language Model",
  "description": "Projecting editor to display response from LLM into text editor. Translates code language into natural language and vice versa.",
  "publisher": "PeterVaverk",
  "repository": {
    "type": "git",
    "url": "https://github.com/PeterVavercak/projecting-editor-natural-language"
  },
  "version": "0.11.0",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "AI"
  ],
  "keywords": [
    "snippets",
    "llm",
    "ai",
    "projecting editor",
    "natural language",
    "collapse",
    "region",
    "folding",
    "show",
    "hide"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:myToolsView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "Generation.generateNL",
        "title": "Write Natural Language",
        "category": "Generation",
        "icon": "$(call-incoming)"
      },
      {
        "command": "Generation.generateCode",
        "title": "Write Code",
        "category": "Generation",
        "icon": "$(call-outgoing)"
      },
      {
        "command": "Generation.generateRegions",
        "category": "Generation",
        "title": "Generate Regions"
      },
      {
        "command": "Projection.showNLRegions",
        "category": "Projection",
        "title": "Show Natural Language Regions"
      },
      {
        "command": "Projection.showCodeRegions",
        "category": "Projection",
        "title": "Show Code Regions"
      },
      {
        "command": "Projection.showEveryRegion",
        "category": "Projection",
        "title": "Show Every Regions"
      },
      {
        "command": "Projection.closeEveryRegion",
        "category": "Projection",
        "title": "Close Every Regions"
      },
      {
        "command": "Projection.restartDecorations",
        "category": "Projection",
        "title": "Reset Decoration"
      }
    ],
    "configuration": {
      "title": "Settings Editor Test Extension",
      "type": "object",
      "properties": {
        "projectingNaturalLanguage.setLanguageModel": {
          "type": "string",
          "enum": [
            "gpt-4o",
            "grok-code-fast-1",
            "gpt-5",
            "gpt-5-mini",
            "gpt-5-nano",
            "gpt-4.1",
            "gpt-4.1-mini",
            "gpt-4.1-nano",
            "gemini-2.5-pro",
            "claude-opus-4.6",
            "claude-sonnet-4.6"
          ],
          "default": "gpt-4o",
          "description": "Language Model"
        },
        "projectingNaturalLanguage.automaticTranslation": {
          "type": "boolean",
          "default": true,
          "description": "Automatic Translation"
        },
        "projectingNaturalLanguage.automaticFolding": {
          "type": "boolean",
          "default": true,
          "description": "Automatic Folding"
        },
        "projectingNaturalLanguage.showDecorations": {
          "type": "boolean",
          "default": false,
          "description": "Show Decorations"
        },
        "projectingNaturalLanguage.excludedLanguages": {
          "order": 7,
          "type": "array",
          "default": [],
          "markdownDescription": "List of languages to exclude from folding. \n\nExample: `['javascript', 'typescript']`."
        }
      }
    },
    "snippets": [
      {
        "language": "c",
        "path": "./snippets/c.json"
      },
      {
        "language": "cpp",
        "path": "./snippets/cpp.json"
      },
      {
        "language": "csharp",
        "path": "./snippets/csharp.json"
      },
      {
        "language": "java",
        "path": "./snippets/java.json"
      },
      {
        "language": "javascript",
        "path": "./snippets/javascript.json"
      },
      {
        "language": "php",
        "path": "./snippets/php.json"
      },
      {
        "language": "python",
        "path": "./snippets/python.json"
      },
      {
        "language": "typescript",
        "path": "./snippets/typescript.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projecting-editor-bar",
          "title": "Projecting Editor",
          "icon": "resources/versions.svg"
        }
      ]
    },
    "views": {
      "projecting-editor-bar": [
        {
          "id": "projectingEditorView",
          "name": "Projecting Editor"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "dependencies": {
    "vscode-languageserver-protocol": "^3.17.5"
  }
}
