{
  "Natural Language region": {
    "prefix": ["NaturalLanguage","#NaturalLanguage"],
    "body": ["/*#NaturalLanguage", "$0", "#EndNaturalLanguage*/", ""]
  },
  "Code Region":{
    "prefix": ["#region", "//#region"],
    "body": ["//#region","$0","//#endregion", ""]
  },
  "Editor Fold":{
    "prefix": ["//<editor-fold>", "<editor-fold>"],
    "body": ["//<editor-fold>","$0","//</editor-fold>", ""]
  }

}